<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="330.0" prefWidth="230.0" spacing="12" alignment="TOP_CENTER"
      nodeOrientation="RIGHT_TO_LEFT"
      style="-fx-background-color: #1a1936;
             -fx-background-radius: 18px;
             -fx-border-radius: 18px;
             -fx-border-color: rgba(255, 255, 255, 0.08);
             -fx-border-width: 1px;
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 5);"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12" />
    </padding>

    <!-- بخش تصویر با پس‌زمینه تیره ملایم برای جلوه بیشتر عکس -->
    <VBox alignment="CENTER"
          style="-fx-background-color: #100f24;
                 -fx-background-radius: 14px;
                 -fx-border-radius: 14px;
                 -fx-border-color: rgba(255, 255, 255, 0.04);"
          prefHeight="150.0" prefWidth="206.0">
        <children>
            <ImageView fx:id="adImageView" fitHeight="140.0" fitWidth="190.0" pickOnBounds="true" preserveRatio="true" />
        </children>
    </VBox>

    <!-- عنوان آگهی با رنگ سفید درخشان و کاملاً خوانا -->
    <HBox alignment="CENTER_RIGHT" prefWidth="206.0">
        <padding>
            <Insets right="4" left="4" />
        </padding>
        <children>
            <Label fx:id="adTitleLabel" text="عنوان آگهی"
                   style="-fx-font-size: 14px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #ffffff;" />
        </children>
    </HBox>

    <Pane VBox.vgrow="ALWAYS" />

    <!-- فیلد قیمت با رنگ صورتی نئونی ملایم -->
    <HBox alignment="CENTER_RIGHT" prefWidth="206.0">
        <padding>
            <Insets right="4" left="4" />
        </padding>
        <children>
            <Label fx:id="adPriceLabel" text="۴۵,۰۰۰,۰۰۰ تومان"
                   style="-fx-font-size: 13px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #ff758c;" />
        </children>
    </HBox>

    <!-- خط جداکننده ظریف برای تفکیک بخش کاربر -->
    <Pane prefHeight="1.0" style="-fx-background-color: rgba(255, 255, 255, 0.08);" />

    <!-- اطلاعات فروشنده در پایین کارت -->
    <HBox alignment="CENTER_LEFT" spacing="8" prefWidth="206.0">
        <padding>
            <Insets right="4" left="4" />
        </padding>
        <children>
            <!-- آواتار با رنگ بنفش روشن برای تضاد و زیبایی -->
            <Circle radius="11.0" fill="#4d44b5" stroke="rgba(255,255,255,0.2)" strokeWidth="1.0" />
            <Label fx:id="usernameLabel" text="نام کاربر"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #b9b8cd;" />
        </children>
    </HBox>

</VBox>