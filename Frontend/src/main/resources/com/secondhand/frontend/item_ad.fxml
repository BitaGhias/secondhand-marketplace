<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="300" prefWidth="220" spacing="15" alignment="TOP_CENTER"
      style="-fx-background-color: #ffffff; -fx-background-radius: 15px; -fx-border-radius: 15px; -fx-border-color: #e0e0e0; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12" />
    </padding>

    <VBox alignment="CENTER" style="-fx-background-color: #f8f9fa; -fx-background-radius: 12px; -fx-border-radius: 12px;" prefHeight="150.0" prefWidth="196.0">
        <children>
            <ImageView fx:id="adImageView" fitHeight="140.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" />
        </children>
    </VBox>

    <Pane VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_LEFT" spacing="0" prefWidth="196.0">
        <children>
            <HBox alignment="CENTER_LEFT" spacing="6">
                <children>
                    <Circle radius="12.0" fill="#bdc3c7" />
                    <Label fx:id="usernameLabel" text="نام کاربر" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                </children>
            </HBox>

            <HBox HBox.hgrow="ALWAYS" />

            <Label fx:id="adTitleLabel" text="عنوان آگهی" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        </children>
    </HBox>

</VBox>