<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.RegisterController"
           style="-fx-background-color: transparent; -fx-padding: 0;">

    <VBox alignment="TOP_CENTER" spacing="0" maxWidth="420" maxHeight="-Infinity"
          style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #302b63, #24243e);
                 -fx-background-radius: 30;
                 -fx-border-color: rgba(255,255,255,0.2);
                 -fx-border-radius: 30;
                 -fx-border-width: 1.5;">

        <!-- ===== Title Bar ===== -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: rgba(0,0,0,0.25);
                     -fx-background-radius: 30 30 0 0;
                     -fx-padding: 10 15;
                     -fx-border-color: rgba(255,255,255,0.05);
                     -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="🚀" style="-fx-text-fill: #f093fb; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="ثبت‌نام" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <HBox HBox.hgrow="ALWAYS" />
                <Button text="─" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#minimizeWindow"/>
                <Button text="✕" style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#closeWindow"/>
            </children>
        </HBox>

        <!-- ===== محتوای اصلی ===== -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0; -fx-border-color: transparent;">
            <content>
                <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20 35 35 35;">

                    <!-- لوگو -->
                    <StackPane>
                        <Rectangle arcWidth="30" arcHeight="30" width="70" height="70"
                                   fill="linear-gradient(to bottom right, #f093fb, #f5576c)"
                                   stroke="rgba(255,255,255,0.3)" strokeWidth="1.5"/>
                        <Label text="🚀" style="-fx-font-size: 35px; -fx-text-fill: white;"/>
                        <effect>
                            <DropShadow color="rgba(245,87,108,0.4)" radius="15" spread="0.1"/>
                        </effect>
                    </StackPane>

                    <VBox alignment="CENTER" spacing="5">
                        <Label text="ایجاد حساب کاربری" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px;"/>
                        <Label text="همین الان ثبت‌نام کنید و فروش خود را شروع کنید" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- فرم ثبت‌نام -->
                    <VBox spacing="12" fillWidth="true" nodeOrientation="RIGHT_TO_LEFT"
                          style="-fx-background-color: rgba(255,255,255,0.02);
                                 -fx-background-radius: 20;
                                 -fx-padding: 20;
                                 -fx-border-color: rgba(255,255,255,0.08);
                                 -fx-border-radius: 20;
                                 -fx-border-width: 1;">

                        <VBox spacing="5">
                            <Label text="👤 نام کامل" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="fullNameField" promptText="نام و نام خانوادگی" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="👤 نام کاربری" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="usernameField" promptText="یک نام کاربری انتخاب کنید" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="📧 ایمیل" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" promptText="example@email.com" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="📱 شماره تلفن" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" promptText="09XXXXXXXXX" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="🔒 رمز عبور" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" promptText="حداقل ۶ کاراکتر" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="✅ تکرار رمز عبور" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="رمز عبور را دوباره وارد کنید" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- ===== لودینگ ===== -->
                        <ProgressIndicator fx:id="loadingIndicator"
                                           style="-fx-progress-color: #667eea;"
                                           visible="false"
                                           maxWidth="50" maxHeight="50"/>

                        <Button fx:id="registerButton" text="✨ ثبت‌نام" maxWidth="Infinity" onAction="#handleRegister"
                                style="-fx-background-color: linear-gradient(to right, #f093fb, #f5576c);
                                       -fx-background-radius: 25;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 16px;
                                       -fx-cursor: hand;
                                       -fx-padding: 14 0;
                                       -fx-effect: dropshadow(gaussian, rgba(245,87,108,0.3), 10, 0, 0, 4);">
                            <VBox.margin>
                                <Insets top="10" right="0" bottom="0" left="0"/>
                            </VBox.margin>
                        </Button>

                        <HBox alignment="CENTER" spacing="5">
                            <children>
                                <Label text="قبلاً ثبت‌نام کرده‌اید؟" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                                <Hyperlink fx:id="loginLink" text="وارد شوید" onAction="#goToLogin"
                                           style="-fx-text-fill: #f093fb;
                                                  -fx-font-size: 13px;
                                                  -fx-font-weight: bold;
                                                  -fx-underline: false;
                                                  -fx-border-color: transparent;"/>
                            </children>
                        </HBox>

                        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>

        <effect>
            <DropShadow color="rgba(0,0,0,0.4)" radius="25" spread="0.05"/>
        </effect>
    </VBox>
</StackPane>