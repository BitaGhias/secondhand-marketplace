<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.LoginController"
           stylesheets="@css/styles.css"
           style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- کارت اصلی دوپنلی -->
    <VBox maxWidth="780" maxHeight="-Infinity" spacing="0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 24;
                 -fx-border-color: #e7ecf2;
                 -fx-border-radius: 24;
                 -fx-border-width: 1;">

        <!-- ===== نوار پنجره ===== -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 24 24 0 0;
                     -fx-padding: 12 16;
                     -fx-border-color: transparent transparent #eef2f6 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="بازار سفید" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="─" onAction="#minimizeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
            <Button text="✕" onAction="#closeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        </HBox>

        <!-- ===== بدنه دوپنلی ===== -->
        <HBox>
            <!-- پنل برند (سمت چپ) -->
            <VBox alignment="CENTER" spacing="18" prefWidth="300" minWidth="300"
                  style="-fx-background-color: linear-gradient(to bottom right, #0ea371, #065f46);
                         -fx-background-radius: 0 0 0 24;
                         -fx-padding: 40 30;">
                <StackPane>
                    <Region minWidth="92" minHeight="92" maxWidth="92" maxHeight="92"
                            style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 26;"/>
                    <Label text="🛍" style="-fx-font-size: 42px;"/>
                </StackPane>
                <Label text="بازار سفید" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="دستِ دوم، حالِ اول ✨" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;"/>
                <Region prefHeight="12"/>
                <Label text="خرید و فروش مطمئن کالای دستِ دوم" wrapText="true" textAlignment="CENTER"
                       style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px;"/>
            </VBox>

            <!-- پنل فرم (سمت راست) -->
            <VBox spacing="18" HBox.hgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT"
                  style="-fx-padding: 40 42;">

                <VBox spacing="6">
                    <Label text="خوش آمدید 👋" style="-fx-text-fill: #0f172a; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="برای ادامه، وارد حساب کاربری خود شوید" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="نام کاربری" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" promptText="نام کاربری خود را وارد کنید"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" promptText="رمز عبور خود را وارد کنید"/>
                </VBox>

                <Label fx:id="errorLabel" visible="false" text=""
                       style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                <Button fx:id="loginButton" text="ورود به حساب" maxWidth="Infinity" onAction="#handleLogin"
                        style="-fx-background-color: #0e9f6e;
                               -fx-background-radius: 12;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 15px;
                               -fx-cursor: hand;
                               -fx-padding: 13 0;
                               -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 12, 0, 0, 4);"/>

                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="28" prefHeight="28"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="حساب کاربری ندارید؟" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Hyperlink fx:id="registerLink" text="ثبت‌نام کنید" onAction="#goToRegister"
                               style="-fx-text-fill: #0e9f6e; -fx-font-size: 12px; -fx-font-weight: bold; -fx-underline: false; -fx-border-color: transparent;"/>
                </HBox>
            </VBox>
        </HBox>

        <effect>
            <DropShadow color="rgba(15,23,42,0.18)" radius="30" spread="0.02"/>
        </effect>
    </VBox>
</StackPane>
