<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.ProgressIndicator?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #302b63, #24243e);">

    <!-- لودینگ (مخفی در ابتدا) -->
    <ProgressIndicator fx:id="loadingIndicator"
                       style="-fx-progress-color: #667eea;"
                       visible="false"
                       maxWidth="50" maxHeight="50"/>

    <!-- کارت اصلی -->
    <VBox alignment="CENTER" spacing="25" maxWidth="420"
          style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 30; -fx-border-width: 1;">

        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <children>
            <!-- لوگو یا آیکون -->
            <StackPane>
                <Rectangle arcWidth="30" arcHeight="30" width="80" height="80"
                           fill="linear-gradient(to bottom right, #667eea, #764ba2)"
                           stroke="rgba(255,255,255,0.2)" strokeWidth="1"/>
                <Label text="🛒" style="-fx-font-size: 40px; -fx-text-fill: white;"/>
                <effect>
                    <DropShadow color="rgba(102,126,234,0.4)" radius="20" spread="0.2"/>
                </effect>
            </StackPane>

            <!-- عنوان -->
            <VBox alignment="CENTER" spacing="5">
                <Label text="به فروشگاه دست دوم خوش آمدید"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 22px;"/>
                <Label text="برای ادامه، وارد حساب خود شوید"
                       style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 14px;"/>
            </VBox>

            <!-- فرم ورود -->
            <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 20; -fx-padding: 20;">

                <!-- فیلد نام کاربری -->
                <VBox spacing="5">
                    <Label text="👤 نام کاربری" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" promptText="نام کاربری خود را وارد کنید"
                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.2)" radius="5"/>
                        </effect>
                    </TextField>
                </VBox>

                <!-- فیلد رمز عبور -->
                <VBox spacing="5">
                    <Label text="🔒 رمز عبور" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" promptText="رمز عبور خود را وارد کنید"
                                   style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.3); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-padding: 12 15; -fx-font-size: 14px;">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.2)" radius="5"/>
                        </effect>
                    </PasswordField>
                </VBox>

                <!-- دکمه ورود -->
                <Button fx:id="loginButton" text="✨ ورود به حساب"
                        style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-background-radius: 25; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 14 0; -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.4), 15, 0, 0, 5);"
                        onAction="#handleLogin"
                        maxWidth="Infinity"/>

                <!-- خط جداکننده -->
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Label style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1; -fx-pref-width: 80;"/>
                        <Label text="یا" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 12px;"/>
                        <Label style="-fx-background-color: rgba(255,255,255,0.1); -fx-pref-height: 1; -fx-pref-width: 80;"/>
                    </children>
                </HBox>

                <!-- لینک ثبت‌نام -->
                <HBox alignment="CENTER" spacing="5">
                    <children>
                        <Label text="حساب کاربری ندارید؟" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
                        <Hyperlink fx:id="registerLink" text="ثبت‌نام کنید"
                                   style="-fx-text-fill: #667eea; -fx-font-size: 13px; -fx-font-weight: bold; -fx-underline: false; -fx-border-color: transparent;"
                                   onAction="#goToRegister"/>
                    </children>
                </HBox>

                <!-- پیام خطا -->
                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px; -fx-wrap-text: true;" visible="false"/>
            </VBox>
        </children>

        <effect>
            <DropShadow color="rgba(0,0,0,0.5)" radius="30" spread="0.1"/>
        </effect>
    </VBox>
</StackPane>