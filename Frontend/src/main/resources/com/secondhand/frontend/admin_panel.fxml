<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdminController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 12 16;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label text="بازار سفید — پنل مدیریت" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== محتوا ===== -->
    <VBox spacing="16" VBox.vgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT">
        <padding>
            <Insets top="18" right="28" bottom="24" left="28"/>
        </padding>

        <!-- سربرگ -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="🛡 پنل مدیریت" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="بررسی آگهی‌های در انتظار تایید و مدیریت کاربران" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </VBox>
            <Button text="↻ به‌روزرسانی" onAction="#refreshAll"
                    style="-fx-background-color: #ffffff;
                           -fx-text-fill: #475569;
                           -fx-border-color: #cbd5e1;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 8 18;"/>
            <Button text="→ بازگشت" onAction="#goBack"
                    style="-fx-background-color: #ffffff;
                           -fx-text-fill: #0e9f6e;
                           -fx-border-color: #0e9f6e;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 8 18;"/>
        </HBox>

        <!-- تب‌ها -->
        <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: transparent;">

            <!-- تب آگهی‌های در انتظار -->
            <Tab text="آگهی‌های در انتظار تایید">
                <content>
                    <HBox spacing="16" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">

                        <!-- لیست آگهی‌ها -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #ffffff;
                                     -fx-background-radius: 16;
                                     -fx-border-color: #e7ecf2;
                                     -fx-border-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
                                     -fx-padding: 18;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="pendingCountLabel" text="در انتظار تایید: ۰"
                                       style="-fx-background-color: #fef3c7;
                                              -fx-background-radius: 20;
                                              -fx-padding: 5 14;
                                              -fx-text-fill: #b45309;
                                              -fx-font-size: 12px;
                                              -fx-font-weight: bold;"/>
                                <Label text="برای مشاهده جزئیات هر آگهی روی آن کلیک کنید"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                            </HBox>
                            <ListView fx:id="pendingItemsListView" VBox.vgrow="ALWAYS"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        </VBox>

                        <!-- پنل عملیات -->
                        <VBox spacing="12" prefWidth="300" minWidth="300"
                              style="-fx-background-color: #ffffff;
                                     -fx-background-radius: 16;
                                     -fx-border-color: #e7ecf2;
                                     -fx-border-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
                                     -fx-padding: 18;">
                            <Label text="عملیات بررسی" style="-fx-text-fill: #0f172a; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                            <Label text="ابتدا یک آگهی را از لیست انتخاب کنید"
                                   wrapText="true" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>

                            <Button fx:id="approveButton" text="✓ تایید آگهی" maxWidth="Infinity" onAction="#approveItem"
                                    style="-fx-background-color: #0e9f6e;
                                           -fx-background-radius: 12;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 11 0;
                                           -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 10, 0, 0, 3);"/>

                            <VBox spacing="6">
                                <Label text="دلیل رد (اختیاری)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextArea fx:id="rejectionReasonArea" promptText="دلیل رد آگهی را بنویسید..." prefRowCount="3" wrapText="true"/>
                            </VBox>

                            <Button fx:id="rejectButton" text="✕ رد آگهی" maxWidth="Infinity" onAction="#rejectItem"
                                    style="-fx-background-color: #ffffff;
                                           -fx-text-fill: #d97706;
                                           -fx-border-color: #d97706;
                                           -fx-border-width: 1.5;
                                           -fx-border-radius: 12;
                                           -fx-background-radius: 12;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 0;"/>

                            <Region VBox.vgrow="ALWAYS"/>

                            <Button fx:id="deleteButton" text="🗑 حذف آگهی" maxWidth="Infinity" onAction="#deleteItemByAdmin"
                                    style="-fx-background-color: #ffffff;
                                           -fx-text-fill: #dc2626;
                                           -fx-border-color: #dc2626;
                                           -fx-border-width: 1.5;
                                           -fx-border-radius: 12;
                                           -fx-background-radius: 12;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 0;"/>
                        </VBox>
                    </HBox>
                </content>
            </Tab>

            <!-- تب کاربران -->
            <Tab text="مدیریت کاربران">
                <content>
                    <VBox spacing="12" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">
                        <VBox spacing="12" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #ffffff;
                                     -fx-background-radius: 16;
                                     -fx-border-color: #e7ecf2;
                                     -fx-border-radius: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
                                     -fx-padding: 18;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="usersCountLabel" text="تعداد کاربران: ۰"
                                       style="-fx-background-color: #e6f7f0;
                                              -fx-background-radius: 20;
                                              -fx-padding: 5 14;
                                              -fx-text-fill: #0b7d59;
                                              -fx-font-size: 12px;
                                              -fx-font-weight: bold;"/>
                                <Label text="برای مشاهده آگهی‌های هر کاربر روی آن دوبار کلیک کنید"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                            </HBox>
                            <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        </VBox>
                    </VBox>
                </content>
            </Tab>
        </TabPane>
    </VBox>
</VBox>
