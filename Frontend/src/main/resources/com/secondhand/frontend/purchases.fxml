<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="500.0" prefWidth="750.0" spacing="20" style="-fx-background-color: #14142b;"
      alignment="TOP_RIGHT" nodeOrientation="RIGHT_TO_LEFT"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.PurchasesController">

    <!-- ===== Title Bar ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: rgba(0,0,0,0.25);
                 -fx-padding: 10 15;
                 -fx-border-color: rgba(255,255,255,0.05);
                 -fx-border-width: 0 0 1 0;">
        <children>
            <Label text="🛒" style="-fx-text-fill: #667eea; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label text="بازار سفید" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
            <HBox HBox.hgrow="ALWAYS" />
            <Button text="─" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#minimizeWindow"/>
            <Button text="☐" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#maximizeWindow"/>
            <Button text="✕" style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#closeWindow"/>
        </children>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <padding><Insets top="15" right="25" bottom="25" left="25"/></padding>
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Label text="🛒 تاریخچه خریدها" style="-fx-text-fill: #00d2d3; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="⬅ بازگشت" onAction="#goBack"
                    style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
        <Separator style="-fx-opacity: 0.1;" />

        <TableView fx:id="purchasesTable" style="-fx-background-color: transparent; -fx-control-inner-background: #1c1c3a;" VBox.vgrow="ALWAYS">
            <placeholder>
                <Label text="هیچ تاریخچه خریدی یافت نشد." style="-fx-text-fill: rgba(255,255,255,0.4);"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
