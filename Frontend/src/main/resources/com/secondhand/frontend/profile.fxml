<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.ProfileController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 12 16;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label text="بازار سفید — پروفایل" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="16" nodeOrientation="RIGHT_TO_LEFT" alignment="TOP_CENTER">
                <padding>
                    <Insets top="18" right="28" bottom="32" left="28"/>
                </padding>

                <!-- سربرگ -->
                <HBox alignment="CENTER_LEFT" spacing="14" maxWidth="680">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="پروفایل کاربری" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="مدیریت اطلاعات حساب و رمز عبور" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="→ بازگشت" onAction="#goBack"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #0e9f6e;
                                   -fx-border-color: #0e9f6e;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 18;"/>
                </HBox>

                <!-- کارت هویت -->
                <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="680"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 22 26;">
                    <StackPane>
                        <Region minWidth="116" minHeight="116" maxWidth="116" maxHeight="116"
                                style="-fx-background-color: #e6f7f0; -fx-background-radius: 58; -fx-border-color: #0e9f6e; -fx-border-radius: 58; -fx-border-width: 2;"/>
                        <ImageView fx:id="avatarImageView" fitWidth="110.0" fitHeight="110.0" pickOnBounds="true" preserveRatio="true"/>
                    </StackPane>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label fx:id="usernameLabel" text="نام کاربری" style="-fx-text-fill: #0f172a; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <Label fx:id="roleLabel" text="کاربر"
                               style="-fx-background-color: #f1f5f9;
                                      -fx-background-radius: 20;
                                      -fx-padding: 4 14;
                                      -fx-font-size: 12px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #475569;"/>

                        <Label fx:id="ratingLabel" text="" visible="false"
                               style="-fx-background-color: #fef3c7;
                                      -fx-background-radius: 20;
                                      -fx-padding: 4 14;
                                      -fx-font-size: 12px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #92400e;"/>
                        <Button text="📷 تغییر عکس پروفایل" onAction="#changeProfilePhoto"
                                style="-fx-background-color: #ffffff;
                                       -fx-text-fill: #0e9f6e;
                                       -fx-border-color: #0e9f6e;
                                       -fx-border-width: 1.5;
                                       -fx-border-radius: 10;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-padding: 7 16;"/>
                    </VBox>
                </HBox>

                <Label fx:id="messageLabel" text="" visible="false" wrapText="true" maxWidth="680"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                <!-- کارت اطلاعات حساب -->
                <VBox spacing="14" maxWidth="680"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 24 26;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="اطلاعات حساب" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="نام کامل" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="fullNameField" promptText="نام و نام خانوادگی"/>
                    </VBox>
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="ایمیل" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" promptText="example@email.com"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="شماره تلفن" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" promptText="09XXXXXXXXX"/>
                        </VBox>
                    </HBox>

                    <Button text="💾 ذخیره تغییرات" onAction="#saveProfile"
                            style="-fx-background-color: #0e9f6e;
                                   -fx-background-radius: 12;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 14px;
                                   -fx-cursor: hand;
                                   -fx-padding: 11 26;
                                   -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 10, 0, 0, 3);"/>
                </VBox>

                <!-- کارت تغییر رمز عبور -->
                <VBox spacing="14" maxWidth="680"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 24 26;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="تغییر رمز عبور" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="رمز عبور فعلی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="oldPasswordField" promptText="رمز عبور فعلی خود را وارد کنید"/>
                    </VBox>
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="رمز عبور جدید" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="newPasswordField" promptText="حداقل ۶ کاراکتر"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="تکرار رمز عبور جدید" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="رمز جدید را دوباره وارد کنید"/>
                        </VBox>
                    </HBox>

                    <Button text="🔑 تغییر رمز عبور" onAction="#changePassword"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #475569;
                                   -fx-border-color: #cbd5e1;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 12;
                                   -fx-background-radius: 12;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;
                                   -fx-padding: 10 24;"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
