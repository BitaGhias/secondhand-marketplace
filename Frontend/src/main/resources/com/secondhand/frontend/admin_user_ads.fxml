<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="800.0" prefWidth="1100.0" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom right, #0f0c29, #201a46, #14142b);"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdminUserAdListController">

    <!-- ===== Title Bar ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: rgba(0,0,0,0.25);
                 -fx-padding: 10 15;
                 -fx-border-color: rgba(255,255,255,0.05);
                 -fx-border-width: 0 0 1 0;">
        <children>
            <Label text="🛒" style="-fx-text-fill: #667eea; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label text="بازار سفید" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
            <HBox HBox.hgrow="ALWAYS" />
            <Button text="─" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#minimizeWindow"/>
            <Button text="☐" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#maximizeWindow"/>
            <Button text="✕" style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;" onAction="#closeWindow"/>
        </children>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <padding><Insets top="15" right="25" bottom="25" left="25"/></padding>

        <!-- هدر -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="← بازگشت به پنل مدیریت" style="-fx-background-color: transparent; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#goBack"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="userTitleLabel" text="👤" style="-fx-text-fill: #f093fb; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </HBox>

        <Separator style="-fx-opacity: 0.1;"/>

        <!-- اطلاعات کاربر و عملیات -->
        <HBox nodeOrientation="RIGHT_TO_LEFT" spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 15; -fx-padding: 15;">
            <Label fx:id="userInfoLabel" style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 13px;"/>
            <Label fx:id="blockStatusLabel" style="-fx-text-fill: #38ef7d; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button fx:id="blockButton" text="🔒 مسدود کردن" onAction="#blockUser"
                    style="-fx-background-color: #ff4757;
                           -fx-text-fill: white;
                           -fx-background-radius: 12;
                           -fx-padding: 10 20;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>
            <Button fx:id="unblockButton" text="🔓 فعال‌سازی" onAction="#unblockUser" visible="false"
                    style="-fx-background-color: #2ed573;
                           -fx-text-fill: white;
                           -fx-background-radius: 12;
                           -fx-padding: 10 20;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>
        </HBox>

        <Label fx:id="messageLabel" style="-fx-font-size: 13px;" visible="false"/>

        <!-- سه بخش آگهی‌ها -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox spacing="18" nodeOrientation="RIGHT_TO_LEFT" style="-fx-background-color: transparent; -fx-padding: 5;">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📌 آگهی‌های ثبت‌شده" style="-fx-text-fill: #667eea; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label fx:id="postedCountLabel" text="0 مورد" style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 13px;"/>
                </HBox>
                <FlowPane fx:id="postedFlowPane" hgap="15" vgap="15" style="-fx-background-color: transparent;"/>

                <Separator style="-fx-opacity: 0.08;"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✅ آگهی‌های فروخته‌شده" style="-fx-text-fill: #38ef7d; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label fx:id="soldCountLabel" text="0 مورد" style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 13px;"/>
                </HBox>
                <FlowPane fx:id="soldFlowPane" hgap="15" vgap="15" style="-fx-background-color: transparent;"/>

                <Separator style="-fx-opacity: 0.08;"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🗑️ آگهی‌های حذف‌شده" style="-fx-text-fill: #ff6b6b; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label fx:id="deletedCountLabel" text="0 مورد" style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 13px;"/>
                </HBox>
                <FlowPane fx:id="deletedFlowPane" hgap="15" vgap="15" style="-fx-background-color: transparent;"/>

            </VBox>
        </ScrollPane>
    </VBox>
</VBox>
