<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.CreateAdController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 12 16;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label text="بازار سفید — ثبت آگهی" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="16" nodeOrientation="RIGHT_TO_LEFT" alignment="TOP_CENTER">
                <padding>
                    <Insets top="18" right="28" bottom="32" left="28"/>
                </padding>

                <!-- سربرگ صفحه -->
                <HBox alignment="CENTER_LEFT" spacing="14" maxWidth="760">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label fx:id="pageTitle" text="ثبت آگهی جدید"
                               style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="مشخصات کالای خود را کامل و دقیق وارد کنید"
                               style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="→ بازگشت" onAction="#goBack"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #0e9f6e;
                                   -fx-border-color: #0e9f6e;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 18;"/>
                </HBox>

                <!-- کارت فرم -->
                <VBox spacing="18" maxWidth="760"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 28 30;">

                    <!-- بخش ۱: اطلاعات آگهی -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="۱" style="-fx-background-color: #0e9f6e; -fx-background-radius: 50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 3 10;"/>
                        <Label text="اطلاعات آگهی" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="عنوان آگهی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="titleField" promptText="مثلاً: گوشی سامسونگ گلکسی S23 در حد نو"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="توضیحات" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextArea fx:id="descriptionArea" promptText="جزئیات کالا، وضعیت سلامت، مدت استفاده و..." prefRowCount="4" wrapText="true"/>
                    </VBox>

                    <!-- بخش ۲: قیمت و دسته‌بندی -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="۲" style="-fx-background-color: #0e9f6e; -fx-background-radius: 50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 3 10;"/>
                        <Label text="قیمت، دسته‌بندی و شهر" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="قیمت (تومان)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="priceField" promptText="مثلاً: 4500000"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="دسته‌بندی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <MenuButton fx:id="categoryMenuButton" text="انتخاب دسته‌بندی" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="شهر" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="cityComboBox" promptText="انتخاب شهر" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <!-- بخش ۳: تصاویر -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="۳" style="-fx-background-color: #0e9f6e; -fx-background-radius: 50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 3 10;"/>
                        <Label text="تصاویر کالا" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <Button text="📷 افزودن تصویر" onAction="#addImage"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #0e9f6e;
                                   -fx-border-color: #0e9f6e;
                                   -fx-border-width: 1.5;
                                   -fx-border-style: segments(6, 4);
                                   -fx-border-radius: 12;
                                   -fx-background-radius: 12;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 13px;
                                   -fx-cursor: hand;
                                   -fx-padding: 12 26;"/>

                    <FlowPane fx:id="imagePreviewContainer" hgap="10" vgap="10"/>

                    <Label fx:id="errorLabel" text="" visible="false" wrapText="true"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                    <Button fx:id="submitButton" text="ثبت و ارسال برای تایید" maxWidth="Infinity" onAction="#submitAd"
                            style="-fx-background-color: #0e9f6e;
                                   -fx-background-radius: 12;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 15px;
                                   -fx-cursor: hand;
                                   -fx-padding: 13 0;
                                   -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 12, 0, 0, 4);"/>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
