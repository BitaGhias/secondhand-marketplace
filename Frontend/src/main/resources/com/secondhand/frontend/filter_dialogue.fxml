<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="380.0" spacing="15" style="-fx-background-color: #1c1c3e; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 15; -fx-border-width: 1;"
      alignment="TOP_RIGHT" nodeOrientation="RIGHT_TO_LEFT"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="20" right="25" bottom="20" left="25"/>
    </padding>

    <Label text="🔍 فیلترهای پیشرفته" style="-fx-text-fill: #38ef7d; -fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Separator style="-fx-opacity: 0.1;" />

    <!-- فیلتر قیمت -->
    <VBox spacing="8">
        <Label text="محدوده قیمت (تومان)" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="minPriceField" promptText="از" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
            <Label text="تا" style="-fx-text-fill: white;"/>
            <TextField fx:id="maxPriceField" promptText="تا" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>

    <!-- فیلتر شهر -->
    <VBox spacing="5">
        <Label text="شهر" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
        <ComboBox fx:id="filterCityComboBox" prefWidth="330" promptText="همه شهرها"
                  style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
    </VBox>

    <!-- فیلتر دسته‌بندی -->
    <VBox spacing="5">
        <Label text="دسته‌بندی" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
        <ComboBox fx:id="filterCategoryComboBox" prefWidth="330" promptText="همه دسته‌بندی‌ها"
                  style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
    </VBox>

    <Region prefHeight="10.0" />

    <!-- دکمه‌ها -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="حذف فیلترها" style="-fx-background-color: transparent; -fx-text-fill: #ff4757; -fx-cursor: hand;"/>
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="اعمال فیلتر" style="-fx-background-color: linear-gradient(to right, #11998e, #38ef7d); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
</VBox>