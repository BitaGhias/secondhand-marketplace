<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="420.0" spacing="16" nodeOrientation="RIGHT_TO_LEFT"
      style="-fx-background-color: #ffffff;
             -fx-background-radius: 18;
             -fx-border-color: #e7ecf2;
             -fx-border-radius: 18;"
      stylesheets="@css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.FilterDialogController">

    <padding>
        <Insets top="24" right="26" bottom="24" left="26"/>
    </padding>

    <!-- سربرگ -->
    <VBox spacing="4">
        <Label text="⚙ فیلتر آگهی‌ها" style="-fx-text-fill: #0f172a; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="نتایج را بر اساس دسته‌بندی، شهر و قیمت محدود کنید" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
    </VBox>

    <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;"/>

    <VBox spacing="6">
        <Label text="دسته‌بندی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <ComboBox fx:id="filterCategoryComboBox" promptText="همه دسته‌بندی‌ها" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="6">
        <Label text="شهر" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <ComboBox fx:id="filterCityComboBox" promptText="همه شهرها" maxWidth="Infinity"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="حداقل قیمت (تومان)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="minPriceField" promptText="مثلاً 100000"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="حداکثر قیمت (تومان)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="maxPriceField" promptText="مثلاً 5000000"/>
        </VBox>
    </HBox>

    <Label fx:id="filterErrorLabel" text="" visible="false" wrapText="true"
           style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Button fx:id="applyFilterButton" text="اعمال فیلتر" onAction="#applyFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #0e9f6e;
                       -fx-background-radius: 12;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-padding: 11 0;
                       -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 10, 0, 0, 3);"/>
        <Button fx:id="clearFilterButton" text="حذف فیلترها" onAction="#clearFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #ffffff;
                       -fx-text-fill: #475569;
                       -fx-border-color: #cbd5e1;
                       -fx-border-width: 1.5;
                       -fx-border-radius: 12;
                       -fx-background-radius: 12;
                       -fx-font-weight: bold;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-padding: 10 0;"/>
    </HBox>
</VBox>
