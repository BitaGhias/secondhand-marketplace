<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="400.0" spacing="15" style="-fx-background-color: #14142b;"
      alignment="TOP_RIGHT" nodeOrientation="RIGHT_TO_LEFT"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.FilterDialogueController">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="⚙️ فیلترهای جست‌وجو" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Separator style="-fx-opacity: 0.1;"/>

    <Label text="دسته‌بندی:" style="-fx-text-fill: rgba(255,255,255,0.7);"/>
    <ComboBox fx:id="filterCategoryComboBox" promptText="همه دسته‌بندی‌ها" maxWidth="Infinity"
              style="-fx-background-color: rgba(255,255,255,0.05);"/>

    <Label text="شهر:" style="-fx-text-fill: rgba(255,255,255,0.7);"/>
    <ComboBox fx:id="filterCityComboBox" promptText="همه شهرها" maxWidth="Infinity"
              style="-fx-background-color: rgba(255,255,255,0.05);"/>

    <Label text="محدوده قیمت (تومان):" style="-fx-text-fill: rgba(255,255,255,0.7);"/>
    <HBox spacing="10">
        <TextField fx:id="minPriceField" promptText="از قیمت" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
        <TextField fx:id="maxPriceField" promptText="تا قیمت" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-background-radius: 8;"/>
    </HBox>

    <Label fx:id="filterErrorLabel" visible="false" style="-fx-text-fill: #ff4757; -fx-font-size: 12px;"/>

    <Separator style="-fx-opacity: 0.1;"/>
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="applyFilterButton" text="اعمال فیلتر" onAction="#applyFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 25; -fx-cursor: hand;"/>
        <Button fx:id="clearFilterButton" text="حذف فیلترها" onAction="#clearFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 25; -fx-cursor: hand;"/>
    </HBox>
</VBox>
