<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdminUserAdListController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 12 16;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label text="بازار سفید — آگهی‌های کاربر" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="16" nodeOrientation="RIGHT_TO_LEFT">
                <padding>
                    <Insets top="18" right="28" bottom="28" left="28"/>
                </padding>

                <!-- سربرگ -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label fx:id="userTitleLabel" text="آگهی‌های کاربر"
                               style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label fx:id="userInfoLabel" text=""
                               style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="→ بازگشت به پنل مدیریت" onAction="#goBack"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #0e9f6e;
                                   -fx-border-color: #0e9f6e;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 18;"/>
                </HBox>

                <!-- کارت وضعیت کاربر -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 16;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 16;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
                             -fx-padding: 14 18;">
                    <Label fx:id="blockStatusLabel" text=""
                           style="-fx-background-color: #f1f5f9;
                                  -fx-background-radius: 20;
                                  -fx-padding: 5 14;
                                  -fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #475569;"/>
                    <Label fx:id="messageLabel" text="" visible="false"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="blockButton" text="🔒 مسدود کردن کاربر" onAction="#blockUser"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #dc2626;
                                   -fx-border-color: #dc2626;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;
                                   -fx-padding: 8 18;"/>
                    <Button fx:id="unblockButton" text="🔓 رفع مسدودیت" onAction="#unblockUser" visible="false"
                            style="-fx-background-color: #0e9f6e;
                                   -fx-background-radius: 10;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 12px;
                                   -fx-cursor: hand;
                                   -fx-padding: 8 18;"/>
                </HBox>

                <!-- آگهی‌های ثبت‌شده -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region minWidth="10" minHeight="10" maxWidth="10" maxHeight="10" style="-fx-background-color: #0e9f6e; -fx-background-radius: 50;"/>
                    <Label text="آگهی‌های ثبت‌شده" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label fx:id="postedCountLabel" text="۰"
                           style="-fx-background-color: #e6f7f0; -fx-background-radius: 20; -fx-padding: 2 10; -fx-text-fill: #0b7d59; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Region style="-fx-background-color: #e7ecf2; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                </HBox>
                <FlowPane fx:id="postedFlowPane" hgap="20" vgap="20" alignment="TOP_RIGHT" style="-fx-background-color: transparent;"/>

                <!-- آگهی‌های فروخته‌شده -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region minWidth="10" minHeight="10" maxWidth="10" maxHeight="10" style="-fx-background-color: #2563eb; -fx-background-radius: 50;"/>
                    <Label text="آگهی‌های فروخته‌شده" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label fx:id="soldCountLabel" text="۰"
                           style="-fx-background-color: #dbeafe; -fx-background-radius: 20; -fx-padding: 2 10; -fx-text-fill: #1d4ed8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Region style="-fx-background-color: #e7ecf2; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                </HBox>
                <FlowPane fx:id="soldFlowPane" hgap="20" vgap="20" alignment="TOP_RIGHT" style="-fx-background-color: transparent;"/>

                <!-- آگهی‌های حذف‌شده -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region minWidth="10" minHeight="10" maxWidth="10" maxHeight="10" style="-fx-background-color: #dc2626; -fx-background-radius: 50;"/>
                    <Label text="آگهی‌های حذف‌شده" style="-fx-text-fill: #0f172a; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label fx:id="deletedCountLabel" text="۰"
                           style="-fx-background-color: #fee2e2; -fx-background-radius: 20; -fx-padding: 2 10; -fx-text-fill: #b91c1c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Region style="-fx-background-color: #e7ecf2; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
                </HBox>
                <FlowPane fx:id="deletedFlowPane" hgap="20" vgap="20" alignment="TOP_RIGHT" style="-fx-background-color: transparent;"/>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
