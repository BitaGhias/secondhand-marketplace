<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.ItemDetailController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #0e2433; -fx-padding: 12 16;">
        <Label text="دست‌دوم مارکت — جزئیات آگهی" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== محتوا ===== -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="16" nodeOrientation="RIGHT_TO_LEFT">
                <padding>
                    <Insets top="18" right="28" bottom="28" left="28"/>
                </padding>

                <!-- سربرگ صفحه -->
                <HBox alignment="CENTER_RIGHT" spacing="14">
                    <Button text="←" onAction="#goBack"
                            style="-fx-background-color: #ffffff;
                                   -fx-text-fill: #f97316;
                                   -fx-border-color: #f97316;
                                   -fx-border-width: 1.5;
                                   -fx-border-radius: 10;
                                   -fx-background-radius: 10;
                                   -fx-cursor: hand;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 18;"/>
                    <Label fx:id="errorLabel" text="" visible="false"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- دو ستون: گالری + اطلاعات -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- کارت گالری تصاویر -->
                    <VBox styleClass="detail-card" spacing="14" alignment="TOP_CENTER" prefWidth="430" minWidth="430"
                          style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 18;
                                 -fx-border-color: #e7ecf2;
                                 -fx-border-radius: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                                 -fx-padding: 18;">
                        <VBox alignment="CENTER" prefHeight="360.0"
                              style="-fx-background-color: #f1f5f9; -fx-background-radius: 12;">
                            <ImageView fx:id="mainImageView" fitHeight="340.0" fitWidth="380.0" pickOnBounds="true" preserveRatio="true"/>
                        </VBox>
                        <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" prefHeight="92.0"
                                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                            <content>
                                <HBox fx:id="thumbnailContainer" spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 4;"/>
                            </content>
                        </ScrollPane>
                    </VBox>

                    <!-- کارت اطلاعات -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff;
                                 -fx-background-radius: 18;
                                 -fx-border-color: #e7ecf2;
                                 -fx-border-radius: 18;
                                 -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                                 -fx-padding: 26 28;">

                        <!-- عنوان + وضعیت -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="titleLabel" text="عنوان آگهی" wrapText="true" HBox.hgrow="ALWAYS"
                                   style="-fx-text-fill: #0f172a; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                            <Label fx:id="statusLabel" text=""
                                   style="-fx-background-color: #fff1e6;
                                          -fx-background-radius: 20;
                                          -fx-padding: 5 14;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #c2410c;"/>
                        </HBox>

                        <!-- جعبه قیمت -->
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-background-color: #fff1e6;
                                     -fx-background-radius: 12;
                                     -fx-padding: 14 18;">
                            <Label text="قیمت" style="-fx-text-fill: #c2410c; -fx-font-size: 13px;"/>
                            <Label fx:id="priceLabel" text=""
                                   style="-fx-text-fill: #f97316; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- مشخصات -->
                        <HBox spacing="10">
                            <Label fx:id="cityLabel" text=""
                                   style="-fx-background-color: #f1f5f9;
                                          -fx-background-radius: 20;
                                          -fx-padding: 5 14;
                                          -fx-font-size: 12px;
                                          -fx-text-fill: #475569;"/>
                            <Label fx:id="categoryLabel" text=""
                                   style="-fx-background-color: #f1f5f9;
                                          -fx-background-radius: 20;
                                          -fx-padding: 5 14;
                                          -fx-font-size: 12px;
                                          -fx-text-fill: #475569;"/>
                        </HBox>

                        <!-- توضیحات -->
                        <VBox spacing="8">
                            <Label text="توضیحات" style="-fx-text-fill: #334155; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                            <Label fx:id="descriptionLabel" text="" wrapText="true"
                                   style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-line-spacing: 4;"/>
                        </VBox>

                        <Region style="-fx-background-color: #eef2f6; -fx-pref-height: 1;"/>

                        <!-- فروشنده -->
                        <HBox alignment="CENTER_LEFT" spacing="10" onMouseClicked="#showSellerProfile" style="-fx-cursor: hand;">
                            <Label text="👤" style="-fx-background-color: #ffedd5; -fx-background-radius: 50; -fx-padding: 7 10; -fx-font-size: 14px;"/>
                            <VBox spacing="1">
                                <Label fx:id="ownerLabel" text="" style="-fx-text-fill: #0f172a; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="ratingLabel" text="" style="-fx-text-fill: #d97706; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- اکشن‌های خریدار -->
                        <HBox fx:id="buyerActions" spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="buyButton" text="🛒 درخواست خرید" onAction="#buyItem"
                                    style="-fx-background-color: #f97316;
                                           -fx-background-radius: 12;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 14px;
                                           -fx-cursor: hand;
                                           -fx-padding: 11 24;
                                           -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.30), 10, 0, 0, 3);"/>
                            <Button fx:id="chatButton" text="💬 گفت‌وگو با فروشنده" onAction="#startChat"
                                    style="-fx-background-color: #ffffff;
                                           -fx-text-fill: #f97316;
                                           -fx-border-color: #f97316;
                                           -fx-border-width: 1.5;
                                           -fx-border-radius: 12;
                                           -fx-background-radius: 12;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 20;"/>
                            <Button fx:id="ratingButton" text="⭐ ثبت امتیاز" onAction="#showRatingDialog"
                                    style="-fx-background-color: #ffffff;
                                           -fx-text-fill: #d97706;
                                           -fx-border-color: #d97706;
                                           -fx-border-width: 1.5;
                                           -fx-border-radius: 12;
                                           -fx-background-radius: 12;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 20;"/>
                            <Button fx:id="favoriteButton" text="🤍" onAction="#toggleFavorite"
                                    style="-fx-background-color: #f1f5f9;
                                           -fx-background-radius: 12;
                                           -fx-border-color: #e7ecf2;
                                           -fx-border-radius: 12;
                                           -fx-font-size: 17px;
                                           -fx-cursor: hand;
                                           -fx-padding: 8 14;"/>
                        </HBox>

                        <!-- اکشن‌های مالک -->
                        <HBox fx:id="ownerActions" spacing="10" alignment="CENTER_LEFT" visible="false">
                            <Button fx:id="editButton" text="✏ ویرایش آگهی" onAction="#editItem"
                                    style="-fx-background-color: #2563eb;
                                           -fx-background-radius: 12;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 20;"/>
                            <Button fx:id="soldButton" text="✓ اعلام فروخته شد" onAction="#markAsSold"
                                    style="-fx-background-color: #16a34a;
                                           -fx-background-radius: 12;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 20;"/>
                            <Button fx:id="deleteButton" text="🗑 حذف آگهی" onAction="#deleteItem"
                                    style="-fx-background-color: #ffffff;
                                           -fx-text-fill: #dc2626;
                                           -fx-border-color: #dc2626;
                                           -fx-border-width: 1.5;
                                           -fx-border-radius: 12;
                                           -fx-background-radius: 12;
                                           -fx-font-weight: bold;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;
                                           -fx-padding: 10 20;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ===== درخواست‌های خرید (فقط صاحب آگهی) ===== -->
                <VBox fx:id="purchaseRequestsCard" spacing="12" visible="false"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 22 28;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📩 درخواست‌های خرید"
                               style="-fx-text-fill: #0f172a; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label fx:id="purchaseRequestsCount" text=""
                               style="-fx-background-color: #ffedd5; -fx-text-fill: #c2410c; -fx-background-radius: 999; -fx-padding: 3 12; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </HBox>
                    <VBox fx:id="purchaseRequestsBox" spacing="10"/>
                </VBox>

                <!-- ===== بخش نظرات ===== -->
                <VBox spacing="14"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 18;
                             -fx-border-color: #e7ecf2;
                             -fx-border-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);
                             -fx-padding: 22 28;">

                    <!-- سرتیتل -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💬 نظرات"
                               style="-fx-text-fill: #0f172a; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label fx:id="commentCountLabel" text="(0)"
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    </HBox>

                    <!-- فرم ارسال نظر (فقط برای کاربران لاگین‌شده) -->
                    <HBox fx:id="addCommentBox" spacing="10" alignment="CENTER_LEFT">
                        <TextArea fx:id="newCommentArea"
                                  promptText="نظر خود را بنویسید..."
                                  prefHeight="72" prefWidth="680" wrapText="true"
                                  style="-fx-background-radius: 12;
                                         -fx-border-radius: 12;
                                         -fx-border-color: #e7ecf2;
                                         -fx-font-size: 13px;
                                         -fx-text-fill: #1f2937;"/>
                        <Button text="✉️ ارسال" onAction="#submitComment"
                                style="-fx-background-color: #f97316;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 13px;
                                       -fx-background-radius: 12;
                                       -fx-cursor: hand;
                                       -fx-padding: 12 22;"/>
                    </HBox>

                    <!-- لیست نظرات -->
                    <VBox fx:id="commentsListBox" spacing="10"/>

                    <!-- خالی بودن -->
                    <Label fx:id="noCommentsLabel" text="هنوز نظری ثبت نشده است."
                           visible="false"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-padding: 8 0;"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
