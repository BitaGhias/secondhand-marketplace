<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="filter-dialog-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.FilterDialogController"
      stylesheets="@../../css/styles.css"
      nodeOrientation="RIGHT_TO_LEFT" spacing="16" prefWidth="420"
      style="-fx-background-color: #f6f8fa;">

    <padding>
        <Insets top="22" right="24" bottom="22" left="24"/>
    </padding>

    <!-- هدر -->
    <VBox spacing="4">
        <Label text="🔍 فیلترهای جست‌وجو" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <Label text="نتایج را دقیق‌تر کنید" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
    </VBox>

    <Separator/>

    <!-- دسته‌بندی (فلای‌اوت تو در تو) -->
    <VBox spacing="6">
        <Label text="دسته‌بندی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <MenuButton fx:id="filterCategoryMenuButton" text="🗂 همه دسته‌بندی‌ها" maxWidth="Infinity"
                    style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #dbe3ea; -fx-border-radius: 10; -fx-padding: 9 12; -fx-cursor: hand; -fx-text-fill: #0f172a;"/>
    </VBox>

    <!-- شهر -->
    <VBox spacing="6">
        <Label text="شهر" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <ComboBox fx:id="filterCityComboBox" promptText="همه شهرها" maxWidth="Infinity"/>
    </VBox>

    <!-- محدوده قیمت -->
    <VBox spacing="6">
        <Label text="محدوده قیمت (تومان)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <HBox spacing="10">
            <TextField fx:id="minPriceField" promptText="از قیمت" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="maxPriceField" promptText="تا قیمت" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- مرتب‌سازی -->
    <VBox spacing="6">
        <Label text="مرتب‌سازی بر اساس" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
        <ComboBox fx:id="sortComboBox" maxWidth="Infinity"/>
    </VBox>

    <Label fx:id="filterErrorLabel" visible="false" text="" wrapText="true"
           style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

    <Separator/>

    <!-- دکمه‌ها -->
    <HBox spacing="10">
        <Button fx:id="applyFilterButton" text="اعمال فیلتر" onAction="#applyFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-padding: 11 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.30), 10, 0, 0, 3);"/>
        <Button fx:id="clearFilterButton" text="حذف فیلترها" onAction="#clearFilter" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #ffffff; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-border-color: #dbe3ea; -fx-border-radius: 10; -fx-padding: 10 0; -fx-cursor: hand;"/>
    </HBox>
</VBox>
