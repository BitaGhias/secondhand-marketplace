<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.LoginController"
           stylesheets="@../../css/styles.css"
           style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- کارت اصلی دوپنلی -->
    <VBox maxWidth="780" maxHeight="-Infinity" spacing="0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 24;
                 -fx-border-color: #e7ecf2;
                 -fx-border-radius: 24;
                 -fx-border-width: 1;">

        <!-- ===== نوار پنجره (نفتی) ===== -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
              style="-fx-background-color: #0e2433;
                     -fx-background-radius: 24 24 0 0;
                     -fx-padding: 12 16;">
            <Label text="دست‌دوم مارکت" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="─" onAction="#minimizeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
            <Button text="✕" onAction="#closeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        </HBox>

        <!-- ===== بدنه دوپنلی ===== -->
        <HBox>
            <!-- پنل برند (نفتی با لهجه نارنجی) -->
            <VBox alignment="CENTER" spacing="18" prefWidth="300" minWidth="300"
                  style="-fx-background-color: linear-gradient(to bottom right, #1b4460, #0e2433);
                         -fx-background-radius: 0 0 0 24;
                         -fx-padding: 40 30;">
                <StackPane>
                    <Region minWidth="92" minHeight="92" maxWidth="92" maxHeight="92"
                            style="-fx-background-color: rgba(249,115,22,0.18); -fx-background-radius: 26; -fx-border-color: rgba(249,115,22,0.45); -fx-border-radius: 26; -fx-border-width: 1;"/>
                    <StackPane>
                        <SVGPath content="M5.6 8 H18.4 L19.5 18.9 A2.3 2.3 0 0 1 17.2 21.4 H6.8 A2.3 2.3 0 0 1 4.5 18.9 Z M9 9.6 V7.4 A3 3 0 0 1 15 7.4 V9.6 H13.6 V7.4 A1.6 1.6 0 0 0 10.4 7.4 V9.6 Z" scaleX="2.4" scaleY="2.4" style="-fx-fill: #ffffff;"/>
                        <SVGPath content="M8.7 14.4 L11.1 16.8 L15.6 12.1" scaleX="2.4" scaleY="2.4" style="-fx-fill: transparent; -fx-stroke: #f97316; -fx-stroke-width: 1.6;"/>
                    </StackPane>
                </StackPane>
                <Label text="دست‌دوم مارکت" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="بخر، بفروش، پس‌انداز کن ✨" style="-fx-text-fill: #fdba74; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region prefHeight="12"/>
                <Label text="خرید و فروش مطمئن کالای دستِ دوم" wrapText="true" textAlignment="CENTER"
                       style="-fx-text-fill: rgba(255,255,255,0.60); -fx-font-size: 12px;"/>
            </VBox>

            <!-- پنل فرم (سمت راست) -->
            <VBox spacing="18" HBox.hgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT"
                  style="-fx-padding: 40 42;">

                <VBox spacing="6">
                    <Label text="خوش آمدید 👋" style="-fx-text-fill: #0f172a; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="برای ادامه، وارد حساب کاربری خود شوید" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="نام کاربری" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" promptText="نام کاربری خود را وارد کنید"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" promptText="رمز عبور خود را وارد کنید"/>
                </VBox>

                <Label fx:id="errorLabel" visible="false" text=""
                       style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                <Button fx:id="loginButton" text="ورود به حساب" maxWidth="Infinity" onAction="#handleLogin"
                        style="-fx-background-color: #f97316;
                               -fx-background-radius: 12;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 15px;
                               -fx-cursor: hand;
                               -fx-padding: 13 0;
                               -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.35), 12, 0, 0, 4);"/>

                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="28" prefHeight="28"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="حساب کاربری ندارید؟" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Hyperlink fx:id="registerLink" text="ثبت‌نام کنید" onAction="#goToRegister"
                               styleClass="auth-link"/>
                </HBox>
            </VBox>
        </HBox>

        <effect>
            <DropShadow color="rgba(14,36,51,0.25)" radius="30" spread="0.02"/>
        </effect>
    </VBox>
</StackPane>
