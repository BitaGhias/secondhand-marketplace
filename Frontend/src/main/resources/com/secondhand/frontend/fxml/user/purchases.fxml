<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="purchases-page" prefHeight="560.0" prefWidth="800.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.PurchasesController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #0e2433; -fx-padding: 12 16;">
        <Label text="دست‌دوم مارکت — خریدهای من" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== محتوا ===== -->
    <VBox spacing="14" VBox.vgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT">
        <padding>
            <Insets top="18" right="28" bottom="24" left="28"/>
        </padding>

        <!-- سربرگ -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="🛒 خریدهای من" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="تاریخچه خریدهای شما" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label text="💡 برای مشاهده جزئیات، روی هر ردیف دوبار کلیک کنید"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-style: italic;"/>
            </VBox>
            <Button text="←" onAction="#goBack"
                    style="-fx-background-color: #ffffff;
                           -fx-text-fill: #f97316;
                           -fx-border-color: #f97316;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 8 18;"/>
        </HBox>

        <!-- کارت جدول -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 16;
                     -fx-border-color: #e7ecf2;
                     -fx-border-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
                     -fx-padding: 14;">
            <TableView fx:id="purchasesTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <placeholder>
                    <Label text="هیچ تاریخچه خریدی یافت نشد." style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</VBox>
