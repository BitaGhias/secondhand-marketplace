<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdItemController"
      onMouseClicked="#handleCardClick"
      prefWidth="232" maxWidth="232" spacing="8" nodeOrientation="RIGHT_TO_LEFT"
      style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e7ecf2; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.07), 12, 0, 0, 4); -fx-padding: 12; -fx-cursor: hand;">

    <!-- تصویر + badge وضعیت + قلب علاقه‌مندی -->
    <StackPane>
        <VBox alignment="CENTER" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12;" minHeight="146" maxHeight="146">
            <ImageView fx:id="adImageView" fitWidth="196" fitHeight="140" preserveRatio="true" smooth="true"/>
        </VBox>
        <Label fx:id="cardBadgeLabel" text="کارکرده" StackPane.alignment="TOP_RIGHT"
               style="-fx-background-color: #ffedd5; -fx-text-fill: #c2410c; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 3 10; -fx-translate-x: -8; -fx-translate-y: 8;"/>
        <Button fx:id="favoriteButton" text="♡" onAction="#toggleFavorite" StackPane.alignment="TOP_LEFT"
                style="-fx-background-color: #ffffff; -fx-background-radius: 999; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-padding: 3 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.20), 6, 0, 0, 1); -fx-translate-x: 8; -fx-translate-y: 8;"/>
    </StackPane>

    <!-- عنوان و قیمت -->
    <Label fx:id="adTitleLabel" text="عنوان آگهی" wrapText="true" maxWidth="208"
           style="-fx-text-fill: #0f172a; -fx-font-size: 13px; -fx-font-weight: bold;"/>
    <HBox alignment="CENTER_LEFT" spacing="6">
        <Label fx:id="adPriceLabel" text="قیمت" style="-fx-text-fill: #ea580c; -fx-font-size: 14px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
        <Label fx:id="ratingLabel" text="" style="-fx-text-fill: #d97706; -fx-font-size: 11px; -fx-font-weight: bold;"/>
    </HBox>

    <Region minHeight="1" maxHeight="1" style="-fx-background-color: #eef2f6;"/>

    <!-- فروشنده و شهر -->
    <HBox alignment="CENTER_LEFT" spacing="7">
        <StackPane>
            <Circle radius="11" style="-fx-fill: #ffedd5; -fx-stroke: #fed7aa; -fx-stroke-width: 1;"/>
            <Label text="👤" style="-fx-font-size: 10px;"/>
        </StackPane>
        <Label fx:id="usernameLabel" text="کاربر" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
        <Label text="📍" style="-fx-font-size: 10px;"/>
        <Label fx:id="cityLabel" text="شهر" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
    </HBox>

    <!-- برای سازگاری با صفحاتی که وضعیت متنی نشان می‌دهند -->
    <Label fx:id="statusLabel" text="" visible="false" managed="false" style="-fx-font-size: 10px;"/>
</VBox>
