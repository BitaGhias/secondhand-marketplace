<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="330.0" prefWidth="232.0" spacing="10" alignment="TOP_CENTER"
      nodeOrientation="RIGHT_TO_LEFT"
      style="-fx-background-color: #ffffff;
             -fx-background-radius: 16px;
             -fx-border-radius: 16px;
             -fx-border-color: #e7ecf2;
             -fx-border-width: 1px;
             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 14, 0, 0, 4);
             -fx-cursor: hand;"
      onMouseClicked="#handleCardClick"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdItemController">

    <padding>
        <Insets top="10" right="10" bottom="12" left="10" />
    </padding>

    <!-- تصویر آگهی -->
    <VBox alignment="CENTER" prefHeight="150.0" prefWidth="212.0"
          style="-fx-background-color: #f1f5f9;
                 -fx-background-radius: 12px;
                 -fx-border-radius: 12px;
                 -fx-border-color: #eef2f6;">
        <children>
            <ImageView fx:id="adImageView" fitHeight="140.0" fitWidth="196.0" pickOnBounds="true" preserveRatio="true" />
        </children>
    </VBox>

    <!-- عنوان -->
    <HBox alignment="CENTER_RIGHT" prefWidth="212.0">
        <padding><Insets right="4" left="4" /></padding>
        <children>
            <Label fx:id="adTitleLabel" text="عنوان آگهی" wrapText="true"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
        </children>
    </HBox>

    <Pane VBox.vgrow="ALWAYS" />

    <!-- قیمت -->
    <HBox alignment="CENTER_RIGHT" prefWidth="212.0">
        <padding><Insets right="4" left="4" /></padding>
        <children>
            <Label fx:id="adPriceLabel" text="۴۵,۰۰۰,۰۰۰ تومان"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0e9f6e;" />
        </children>
    </HBox>

    <Pane prefHeight="1.0" style="-fx-background-color: #eef2f6;" />

    <!-- فروشنده + شهر -->
    <HBox alignment="CENTER_LEFT" spacing="8" prefWidth="212.0">
        <padding><Insets right="4" left="4" /></padding>
        <children>
            <Circle radius="10.0" fill="#d1f0e2" stroke="#0e9f6e" strokeWidth="1.0" />
            <Label fx:id="usernameLabel" text="نام کاربر"
                   style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="cityLabel" text=""
                   style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
        </children>
    </HBox>

    <!-- وضعیت آگهی (مخفی — در صفحه آگهی‌های من استفاده می‌شود) -->
    <Label fx:id="statusLabel" visible="false" />

</VBox>
