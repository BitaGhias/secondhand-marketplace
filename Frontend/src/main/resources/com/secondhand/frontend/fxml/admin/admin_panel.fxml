<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdminController"
      stylesheets="@../../css/styles.css"
      style="-fx-background-color: #f6f8fa; -fx-background-radius: 24; -fx-border-color: #e7ecf2; -fx-border-radius: 24; -fx-border-width: 1;">

    <!-- ===== نوار پنجره (نفتی) ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #0e2433; -fx-background-radius: 24 24 0 0; -fx-padding: 12 16;">
        <Label text="دست‌دوم مارکت — پنل مدیریت" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== بدنه: سایدبار تیره + محتوا ===== -->
    <HBox VBox.vgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT">

        <!-- سایدبار نفتی -->
        <VBox spacing="6" minWidth="230" maxWidth="230"
              style="-fx-background-color: #0e2433; -fx-background-radius: 0 0 0 24; -fx-padding: 22 14;">

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 4 14 4;">
                <StackPane>
                    <Region style="-fx-background-color: linear-gradient(to bottom right, #1b4460, #0e2433); -fx-background-radius: 12; -fx-min-width: 38; -fx-min-height: 38; -fx-max-width: 38; -fx-max-height: 38; -fx-border-color: rgba(249,115,22,0.55); -fx-border-radius: 12; -fx-border-width: 1;"/>
                    <SVGPath content="M12 2 L20 5 V11 C20 16.5 16.6 20.8 12 22 C7.4 20.8 4 16.5 4 11 V5 Z" scaleX="1.05" scaleY="1.05" style="-fx-fill: #ffffff;"/>
                    <SVGPath content="M8.6 12.2 L11 14.6 L15.4 10.1" scaleX="1.05" scaleY="1.05" style="-fx-fill: transparent; -fx-stroke: #f97316; -fx-stroke-width: 1.8;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="پنل مدیریت" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="دست‌دوم مارکت" style="-fx-text-fill: #fdba74; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <Button fx:id="navDashboardButton" text="📊  داشبورد" maxWidth="Infinity" onAction="#showDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.72); -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <HBox alignment="CENTER_LEFT">
                <Button fx:id="navPendingButton" text="📋  بررسی آگهی‌ها" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#showPending"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.72); -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
                <Label fx:id="sidebarPendingBadge" text="0" visible="false" managed="false"
                       style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 2 8;"/>
            </HBox>

            <Button fx:id="navUsersButton" text="👥  کاربران" maxWidth="Infinity" onAction="#showUsers"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.72); -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="navCategoriesButton" text="📂  دسته‌بندی‌ها" maxWidth="Infinity" onAction="#showCategories"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.72); -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="🔄  بروزرسانی همه" maxWidth="Infinity" onAction="#refreshAll"
                    style="-fx-background-color: #143449; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 10; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="←" maxWidth="Infinity" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.55); -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 10; -fx-padding: 10 16; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
        </VBox>

        <!-- محتوا -->
        <StackPane HBox.hgrow="ALWAYS" style="-fx-background-color: #f6f8fa; -fx-background-radius: 0 0 24 0;">

            <!-- ===== داشبورد ===== -->
            <VBox fx:id="dashboardPane" spacing="18" style="-fx-padding: 26;">
                <VBox spacing="3">
                    <Label text="📊 داشبورد" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="نمای کلی وضعیت بازار" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: linear-gradient(to bottom right, #1b4460, #0e2433); -fx-background-radius: 16; -fx-padding: 18;">
                        <Label text="⏳ در انتظار بررسی" style="-fx-text-fill: rgba(255,255,255,0.70); -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="dashPendingLabel" text="—" style="-fx-text-fill: #fdba74; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                        <Label text="آگهی منتظر تصمیم شماست" style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 10px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e7ecf2; -fx-border-radius: 16; -fx-padding: 18;">
                        <Label text="📢 آگهی فعال" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="dashActiveLabel" text="—" style="-fx-text-fill: #f97316; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                        <Label text="در حال نمایش به خریداران" style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e7ecf2; -fx-border-radius: 16; -fx-padding: 18;">
                        <Label text="👥 کاربران" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="dashUsersLabel" text="—" style="-fx-text-fill: #0e2433; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                        <Label text="ثبت‌نام شده در سیستم" style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e7ecf2; -fx-border-radius: 16; -fx-padding: 18;">
                        <Label text="📂 دسته‌بندی‌ها" style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="dashCategoriesLabel" text="—" style="-fx-text-fill: #0e2433; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                        <Label text="دسته و زیردسته فعال" style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;"/>
                    </VBox>
                </HBox>

                <VBox spacing="10" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-border-color: #e7ecf2; -fx-border-radius: 16; -fx-padding: 18;">
                    <Label text="⚡ دسترسی سریع" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="از منوی کنار، بخش مورد نظر را انتخاب کنید. آگهی‌های در انتظار را می‌توانید مستقیماً داخل جدول تایید یا رد کنید — بدون باز کردن صفحهٔ جداگانه." wrapText="true"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>
            </VBox>

            <!-- ===== بررسی آگهی‌ها (جدول با اکشن اینلاین) ===== -->
            <VBox fx:id="pendingPane" spacing="12" visible="false" managed="false" style="-fx-padding: 26;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📋 بررسی آگهی‌ها" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="pendingCountLabel" text=""
                           style="-fx-background-color: #fff1e6; -fx-text-fill: #c2410c; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 3 12;"/>
                </HBox>
                <Label text="تایید، رد (با دلیل) یا حذف — مستقیماً داخل هر ردیف جدول. دابل‌کلیک = جزئیات کامل + تصاویر" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- ===== کاربران ===== -->
            <VBox fx:id="usersPane" spacing="12" visible="false" managed="false" style="-fx-padding: 26;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👥 کاربران" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="usersCountLabel" text=""
                           style="-fx-background-color: #ffedd5; -fx-text-fill: #7c2d12; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 3 12;"/>
                </HBox>
                <Label text="برای مدیریت آگهی‌ها و مسدودسازی، روی کاربر کلیک کنید" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- ===== دسته‌بندی‌ها ===== -->
            <VBox fx:id="categoriesPane" spacing="12" visible="false" managed="false" style="-fx-padding: 26;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📂 دسته‌بندی‌ها" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="categoriesCountLabel" text=""
                           style="-fx-background-color: #ffedd5; -fx-text-fill: #7c2d12; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 3 12;"/>
                </HBox>
                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <ListView fx:id="categoriesListView" HBox.hgrow="ALWAYS"/>
                    <VBox spacing="12" minWidth="270" maxWidth="270"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #e7ecf2; -fx-border-radius: 14; -fx-padding: 18;">
                        <Label text="افزودن / ویرایش دسته" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Separator/>
                        <VBox spacing="6">
                            <Label text="نام دسته‌بندی" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <TextField fx:id="categoryNameField" promptText="مثلاً لوازم خانگی"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="دسته والد" style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <MenuButton fx:id="parentCategoryMenuButton" text="بدون والد (دستهٔ اصلی)" maxWidth="Infinity"
                                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #dbe3ea; -fx-border-radius: 10; -fx-padding: 8 12; -fx-cursor: hand; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <Button fx:id="addCategoryButton" text="➕ افزودن دسته‌بندی" maxWidth="Infinity" onAction="#addOrUpdateCategory"
                                style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.30), 8, 0, 0, 2);"/>
                        <Button fx:id="cancelCategoryEditButton" text="انصراف از ویرایش" maxWidth="Infinity" onAction="#cancelCategoryEdit"
                                style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 9 0; -fx-cursor: hand;"/>
                        <Button fx:id="deleteCategoryButton" text="🗑 حذف دستهٔ انتخاب‌شده" maxWidth="Infinity" onAction="#deleteCategory"
                                style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #fecaca; -fx-border-radius: 10; -fx-padding: 9 0; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </HBox>
</VBox>
