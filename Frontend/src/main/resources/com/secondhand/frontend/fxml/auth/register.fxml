<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.RegisterController"
           stylesheets="@../../css/styles.css"
           style="-fx-background-color: transparent; -fx-padding: 0;">

    <VBox maxWidth="820" maxHeight="-Infinity" spacing="0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 24;
                 -fx-border-color: #e7ecf2;
                 -fx-border-radius: 24;
                 -fx-border-width: 1;">

        <!-- ===== نوار پنجره ===== -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 24 24 0 0;
                     -fx-padding: 12 16;
                     -fx-border-color: transparent transparent #eef2f6 transparent;
                     -fx-border-width: 0 0 1 0;">
            <Label text="بازار سفید — ثبت‌نام" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="─" onAction="#minimizeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
            <Button text="✕" onAction="#closeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        </HBox>

        <HBox>
            <!-- پنل برند -->
            <VBox alignment="CENTER" spacing="18" prefWidth="280" minWidth="280"
                  style="-fx-background-color: linear-gradient(to bottom right, #0ea371, #065f46);
                         -fx-background-radius: 0 0 0 24;
                         -fx-padding: 40 28;">
                <StackPane>
                    <Region minWidth="84" minHeight="84" maxWidth="84" maxHeight="84"
                            style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 24;"/>
                    <Label text="🛍" style="-fx-font-size: 38px;"/>
                </StackPane>
                <Label text="به بازار سفید بپیوندید" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="دستِ دوم، حالِ اول ✨" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
                <Region prefHeight="8"/>
                <Label text="در چند ثانیه حساب بسازید و اولین آگهی خود را ثبت کنید" wrapText="true" textAlignment="CENTER"
                       style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 12px;"/>
            </VBox>

            <!-- پنل فرم -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" HBox.hgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0; -fx-border-color: transparent;">
                <content>
                    <VBox spacing="14" nodeOrientation="RIGHT_TO_LEFT" style="-fx-padding: 32 38;">

                        <VBox spacing="5">
                            <Label text="ایجاد حساب کاربری" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            <Label text="اطلاعات زیر را تکمیل کنید" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                        </VBox>

                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="نام کامل" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="fullNameField" promptText="نام و نام خانوادگی"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="نام کاربری" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="usernameField" promptText="یک نام کاربری انتخاب کنید"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="ایمیل" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="emailField" promptText="example@email.com"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="شماره تلفن" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="phoneField" promptText="09XXXXXXXXX"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <PasswordField fx:id="passwordField" promptText="حداقل ۶ کاراکتر"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="تکرار رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <PasswordField fx:id="confirmPasswordField" promptText="رمز عبور را دوباره وارد کنید"/>
                            </VBox>
                        </HBox>

                        <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="40" maxHeight="40"/>

                        <Button fx:id="registerButton" text="ثبت‌نام" maxWidth="Infinity" onAction="#handleRegister"
                                style="-fx-background-color: #0e9f6e;
                                       -fx-background-radius: 12;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-font-size: 15px;
                                       -fx-cursor: hand;
                                       -fx-padding: 13 0;
                                       -fx-effect: dropshadow(gaussian, rgba(14,159,110,0.30), 12, 0, 0, 4);">
                            <VBox.margin>
                                <Insets top="6"/>
                            </VBox.margin>
                        </Button>

                        <HBox alignment="CENTER" spacing="4">
                            <Label text="قبلاً ثبت‌نام کرده‌اید؟" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Hyperlink fx:id="loginLink" text="وارد شوید" onAction="#goToLogin"
                                       style="-fx-text-fill: #0e9f6e; -fx-font-size: 12px; -fx-font-weight: bold; -fx-underline: false; -fx-border-color: transparent;"/>
                        </HBox>

                        <Label fx:id="errorLabel" text="" visible="false"
                               style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-wrap-text: true;"/>
                    </VBox>
                </content>
            </ScrollPane>
        </HBox>

        <effect>
            <DropShadow color="rgba(15,23,42,0.18)" radius="30" spread="0.02"/>
        </effect>
    </VBox>
</StackPane>
