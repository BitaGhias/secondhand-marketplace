<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.secondhand.frontend.controller.RegisterController"
           stylesheets="@../../css/styles.css"
           style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- کارت اصلی دوپنلی -->
    <VBox styleClass="auth-card" maxWidth="820" maxHeight="-Infinity" spacing="0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 24;
                 -fx-border-color: #e7ecf2;
                 -fx-border-radius: 24;
                 -fx-border-width: 1;">

        <!-- ===== نوار پنجره (نفتی) ===== -->
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
              style="-fx-background-color: #0e2433;
                     -fx-background-radius: 24 24 0 0;
                     -fx-padding: 12 16;">
            <Label text="دست‌دوم مارکت" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="─" onAction="#minimizeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
            <Button text="✕" onAction="#closeWindow"
                    style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        </HBox>

        <!-- ===== بدنه دوپنلی ===== -->
        <HBox>
            <!-- پنل برند -->
            <VBox alignment="CENTER" spacing="18" prefWidth="290" minWidth="290"
                  style="-fx-background-color: linear-gradient(to bottom right, #1b4460, #0e2433);
                         -fx-background-radius: 0 0 0 24;
                         -fx-padding: 40 30;">
                <StackPane>
                    <Region minWidth="92" minHeight="92" maxWidth="92" maxHeight="92"
                            style="-fx-background-color: rgba(249,115,22,0.18); -fx-background-radius: 26; -fx-border-color: rgba(249,115,22,0.45); -fx-border-radius: 26; -fx-border-width: 1;"/>
                    <Label text="🌟" style="-fx-font-size: 42px;"/>
                </StackPane>
                <Label text="به جمع ما بپیوندید" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="بخر، بفروش، پس‌انداز کن ✨" style="-fx-text-fill: #fdba74; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region prefHeight="12"/>
                <Label text="ثبت‌نام رایگان است و کمتر از یک دقیقه طول می‌کشد" wrapText="true" textAlignment="CENTER"
                       style="-fx-text-fill: rgba(255,255,255,0.60); -fx-font-size: 12px;"/>
            </VBox>

            <!-- پنل فرم -->
            <VBox spacing="14" HBox.hgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT"
                  style="-fx-padding: 32 42;">

                <VBox spacing="4">
                    <Label text="ساخت حساب کاربری" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="اطلاعات زیر را تکمیل کنید" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </VBox>

                <HBox spacing="12">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="نام و نام خانوادگی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="fullNameField" promptText="مثلاً علی محمدی"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="نام کاربری" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="usernameField" promptText="مثلاً ali_m"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="ایمیل" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="emailField" promptText="example@mail.com"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="شماره تلفن" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="phoneField" promptText="09xxxxxxxxx"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="passwordField" promptText="حداقل ۶ کاراکتر، بدون فاصله"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="تکرار رمز عبور" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="تکرار رمز عبور"/>
                    </VBox>
                </HBox>

                <Label fx:id="errorLabel" visible="false" text="" wrapText="true"
                       style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                <Button fx:id="registerButton" styleClass="auth-primary-button" text="ثبت‌نام و ورود" maxWidth="Infinity" onAction="#handleRegister"
                        style="-fx-background-color: #f97316;
                               -fx-background-radius: 12;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 15px;
                               -fx-cursor: hand;
                               -fx-padding: 13 0;
                               -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.35), 12, 0, 0, 4);"/>

                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="28" prefHeight="28"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="قبلاً ثبت‌نام کرده‌اید؟" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                    <Hyperlink fx:id="loginLink" text="وارد شوید" onAction="#goToLogin"
                               styleClass="auth-link"/>
                </HBox>
            </VBox>
        </HBox>

        <effect>
            <DropShadow color="rgba(14,36,51,0.25)" radius="30" spread="0.02"/>
        </effect>
    </VBox>
</StackPane>