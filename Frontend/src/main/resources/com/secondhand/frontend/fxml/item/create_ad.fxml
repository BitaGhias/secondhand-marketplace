<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ProgressBar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.CreateAdController"
      stylesheets="@../../css/styles.css"
      style="-fx-background-color: #f6f8fa; -fx-background-radius: 24; -fx-border-color: #e7ecf2; -fx-border-radius: 24; -fx-border-width: 1;">

    <!-- ===== نوار پنجره (نفتی) ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #0e2433; -fx-background-radius: 24 24 0 0; -fx-padding: 12 16;">
        <Label text="دیباچه" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox alignment="TOP_CENTER" nodeOrientation="RIGHT_TO_LEFT" style="-fx-padding: 26 0 30 0;">

            <!-- کارت فرم ویزارد -->
            <VBox maxWidth="640" spacing="18"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 18; -fx-border-color: #e7ecf2; -fx-border-radius: 18; -fx-border-width: 1; -fx-padding: 28 32; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.06), 16, 0, 0, 5);">

                <!-- هدر -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="pageTitle" text="➕ ثبت آگهی جدید" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="←" onAction="#goBack"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 10; -fx-padding: 7 14; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- نشانگر مراحل ویزارد -->
                <ProgressBar fx:id="wizardProgressBar" progress="0.33" maxWidth="Infinity" prefHeight="7" style="-fx-accent: #f97316; -fx-control-inner-background: #eef2f6; -fx-background-color: transparent;"/>
                <HBox alignment="CENTER" spacing="8">
                    <Label fx:id="stepLabel1" text="۱. مشخصات"/>
                    <Label text="←" style="-fx-text-fill: #cbd5e1;"/>
                    <Label fx:id="stepLabel2" text="۲. توضیحات و قیمت"/>
                    <Label text="←" style="-fx-text-fill: #cbd5e1;"/>
                    <Label fx:id="stepLabel3" text="۳. تصاویر و ثبت"/>
                </HBox>

                <StackPane>
                    <!-- مرحله ۱: مشخصات -->
                    <VBox fx:id="step1Box" spacing="14">
                        <VBox spacing="6">
                            <Label text="عنوان آگهی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="titleField" promptText="مثلاً گوشی آیفون ۱۳ در حد نو"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="دسته‌بندی" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <MenuButton fx:id="categoryMenuButton" text="📂 انتخاب دسته‌بندی" maxWidth="Infinity"
                                        style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #dbe3ea; -fx-border-radius: 10; -fx-padding: 9 12; -fx-cursor: hand; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="شهر" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="cityComboBox" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>

                    <!-- مرحله ۲: توضیحات و قیمت -->
                    <VBox fx:id="step2Box" spacing="14" visible="false" managed="false">
                        <VBox spacing="6">
                            <Label text="توضیحات" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextArea fx:id="descriptionArea" promptText="جزئیات کالا، وضعیت سلامت، مدت استفاده و..." prefRowCount="6" wrapText="true"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="قیمت (تومان)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="priceField" promptText="مثلاً 25000000"/>
                        </VBox>
                    </VBox>

                    <!-- مرحله ۳: تصاویر -->
                    <VBox fx:id="step3Box" spacing="14" visible="false" managed="false">
                        <Label text="تصاویر آگهی (اختیاری)" style="-fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <VBox fx:id="dropZone" alignment="CENTER" spacing="10" minHeight="180">
                            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                            <Label text="🖼️ تصاویر را اینجا بکشید و رها کنید" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                            <Label text="یا" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                            <Button text="📁 انتخاب از فایل‌ها" onAction="#addImage"
                                    style="-fx-background-color: #ffffff; -fx-text-fill: #ea580c; -fx-font-weight: bold; -fx-background-radius: 10; -fx-border-color: #f97316; -fx-border-radius: 10; -fx-padding: 8 18; -fx-cursor: hand; -fx-font-size: 12px;"/>
                            <FlowPane fx:id="imagePreviewContainer" hgap="10" vgap="10" alignment="CENTER"/>
                        </VBox>
                        <Label text="پس از ثبت، آگهی شما توسط ادمین بررسی و سپس منتشر می‌شود." wrapText="true"
                               style="-fx-background-color: #fff1e6; -fx-text-fill: #c2410c; -fx-background-radius: 10; -fx-padding: 10 14; -fx-font-size: 12px;"/>
                    </VBox>
                </StackPane>

                <Label fx:id="errorLabel" visible="false" text="" wrapText="true"
                       style="-fx-text-fill: #dc2626; -fx-font-size: 13px;"/>

                <!-- ناوبری ویزارد -->
                <HBox spacing="10">
                    <Button fx:id="backStepButton" text="→ مرحله قبل" onAction="#prevStep" visible="false" managed="false"
                            style="-fx-background-color: #ffffff; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-color: #dbe3ea; -fx-border-radius: 12; -fx-padding: 11 22; -fx-cursor: hand; -fx-font-size: 13px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="nextStepButton" text="مرحله بعد ←" onAction="#nextStep"
                            style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 11 26; -fx-cursor: hand; -fx-font-size: 13px; -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.30), 10, 0, 0, 3);"/>
                    <Button fx:id="submitButton" text="✅ ثبت نهایی آگهی" onAction="#submitAd" visible="false" managed="false"
                            style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 11 26; -fx-cursor: hand; -fx-font-size: 13px; -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.30), 10, 0, 0, 3);"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
