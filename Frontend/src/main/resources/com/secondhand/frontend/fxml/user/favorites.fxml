<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="favorites-page" prefHeight="700.0" prefWidth="1000.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.FavoritesController">

    <!-- ===== ЩҶЩҲШ§Шұ ЩҫЩҶШ¬ШұЩҮ ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #0e2433; -fx-padding: 12 16;">
        <Label text="ШҜЫҢШЁШ§ЪҶЩҮ вҖ” Ш№Щ„Ш§ЩӮЩҮвҖҢЩ…ЩҶШҜЫҢвҖҢЩҮШ§" style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="в”Җ" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="вҳҗ" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="вң•" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #f87171; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== Щ…ШӯШӘЩҲШ§ ===== -->
    <VBox spacing="14" VBox.vgrow="ALWAYS" nodeOrientation="RIGHT_TO_LEFT">
        <padding>
            <Insets top="18" right="28" bottom="24" left="28"/>
        </padding>

        <!-- ШіШұШЁШұЪҜ -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="вқӨпёҸ Ш№Щ„Ш§ЩӮЩҮвҖҢЩ…ЩҶШҜЫҢвҖҢЩҮШ§" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ЩҶШҙШ§ЩҶ Ъ©ШұШҜЩҮвҖҢШ§ЫҢШҜ" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            </VBox>
            <Button text="вҶҗ" onAction="#goBack"
                    style="-fx-background-color: #ffffff;
                           -fx-text-fill: #f97316;
                           -fx-border-color: #f97316;
                           -fx-border-width: 1.5;
                           -fx-border-radius: 10;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 8 18;"/>
        </HBox>

        <!-- ЪҜШұЫҢШҜ Ъ©Ш§ШұШӘвҖҢЩҮШ§ -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <FlowPane fx:id="favoritesFlowPane" hgap="20" vgap="20"
                          alignment="TOP_RIGHT" nodeOrientation="RIGHT_TO_LEFT"
                          style="-fx-background-color: transparent;">
                    <children>
                        <Label fx:id="noFavoritesLabel" text="Щ„ЫҢШіШӘ Ш№Щ„Ш§ЩӮЩҮвҖҢЩ…ЩҶШҜЫҢвҖҢЩҮШ§ЫҢ ШҙЩ…Ш§ Ш®Ш§Щ„ЫҢ Ш§ШіШӘ." visible="false"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
