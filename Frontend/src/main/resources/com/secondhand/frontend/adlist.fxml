<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="0"
      style="-fx-background-color: #f5f7fa;"
      stylesheets="@css/styles.css"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.secondhand.frontend.controller.AdListController">

    <!-- ===== نوار پنجره ===== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="10" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 12 16;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">
        <Label text="بازار سفید" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 13px;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="─" onAction="#minimizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="☐" onAction="#maximizeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
        <Button text="✕" onAction="#closeWindow"
                style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 6;"/>
    </HBox>

    <!-- ===== نوار اصلی: منوی کاربر (چپ) | فیلتر | جستجو (راست) | برند (راست‌ترین) ===== -->
    <HBox alignment="CENTER_LEFT" spacing="16" nodeOrientation="LEFT_TO_RIGHT"
          style="-fx-background-color: #ffffff;
                 -fx-padding: 14 24;
                 -fx-border-color: transparent transparent #e7ecf2 transparent;
                 -fx-border-width: 0 0 1 0;">

        <!-- منوی کاربر (سمت چپ) -->
        <MenuButton fx:id="userMenuButton" prefHeight="42.0" prefWidth="160.0"
                    text="👤 نام کاربر" textAlignment="CENTER"
                    style="-fx-background-color: #f1f5f9;
                           -fx-border-color: #e7ecf2;
                           -fx-border-radius: 12;
                           -fx-background-radius: 12;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;">
            <items>
                <MenuItem text="➕ ثبت آگهی جدید" />
                <MenuItem text="📝 آگهی‌های من" />
                <MenuItem text="❤️ علاقه‌مندی‌ها" />
                <MenuItem text="💬 گفت‌وگوها" />
                <MenuItem text="🛒 خریدها" />
                <MenuItem text="👤 پروفایل" />
                <MenuItem text="خروج"/>
            </items>
        </MenuButton>

        <!-- فاصله‌انداز — جستجو و برند را به سمت راست می‌راند -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- فیلترها -->
        <Button text="⚙ فیلترها" onAction="#showFilterDialog" prefHeight="42.0"
                style="-fx-background-color: #ffffff;
                       -fx-text-fill: #0e9f6e;
                       -fx-border-color: #0e9f6e;
                       -fx-border-width: 1.5;
                       -fx-border-radius: 12;
                       -fx-background-radius: 12;
                       -fx-font-weight: bold;
                       -fx-font-size: 13px;
                       -fx-padding: 0 18;
                       -fx-cursor: hand;"/>


        <!-- جستجو (سمت راست، کنار برند) -->
        <HBox alignment="CENTER_LEFT" prefHeight="44.0" prefWidth="480.0" maxWidth="480.0"
              style="-fx-background-color: #f1f5f9;
                     -fx-background-radius: 22;
                     -fx-border-color: #e7ecf2;
                     -fx-border-radius: 22;">
            <TextField fx:id="searchField" promptText="جستجو در آگهی‌ها..." HBox.hgrow="ALWAYS" prefHeight="44.0"
                       nodeOrientation="RIGHT_TO_LEFT"
                       style="-fx-background-color: transparent;
                              -fx-border-color: transparent;
                              -fx-text-fill: #1f2937;
                              -fx-prompt-text-fill: #9aa7b8;
                              -fx-font-size: 13px;
                              -fx-padding: 0 12;"/>
            <Button text="🔍" onAction="#handleSearchClick" prefHeight="44.0" prefWidth="46.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-size: 14px;"/>
        </HBox>

        <!-- برند (راست‌ترین) -->
        <VBox spacing="2" alignment="CENTER_RIGHT">
            <Label text="بازار سفید" style="-fx-text-fill: #0f172a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="خرید و فروش کالای دستِ دوم" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- ===== محتوا ===== -->
    <VBox spacing="14" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="24" left="24" right="24" top="18"/>
        </padding>

        <!-- سرتیتر بخش -->
        <HBox alignment="CENTER_LEFT" spacing="12" nodeOrientation="RIGHT_TO_LEFT">
            <Label text="آگهی‌های تازه" style="-fx-text-fill: #0f172a; -fx-font-size: 17px; -fx-font-weight: bold;"/>
            <Region style="-fx-background-color: #e7ecf2; -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- گرید کارت‌های آگهی -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;
                           -fx-padding: 2 0 0 0;">
            <content>
                <FlowPane fx:id="adsFlowPane" hgap="20" vgap="20"
                          alignment="TOP_RIGHT" nodeOrientation="RIGHT_TO_LEFT"
                          style="-fx-background-color: transparent;">
                    <!-- کارت‌های آگهی (item_ad.fxml) به صورت داینامیک اینجا چیده می‌شوند -->
                </FlowPane>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
