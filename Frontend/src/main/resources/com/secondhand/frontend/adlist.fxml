<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="790.0" prefWidth="1119.0" spacing="10" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.AdListController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 5 0;">
        <children>
            <MenuButton fx:id="userMenuButton" prefHeight="53.0" prefWidth="138.0" style="-fx-background-color: #ffffff;-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" text="نام کاربر" textAlignment="CENTER">
                <items>
                    <MenuItem text="آگهی های من" />
                    <MenuItem text="علاقه مندی های" />
                    <MenuItem text="گفت و گو ها" />
                    <MenuItem text="خریدها" />
                </items>
            </MenuButton>

            <HBox HBox.hgrow="ALWAYS" />

            <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="بازار سفید">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
        </children>
    </HBox>

    <Separator prefWidth="600.0" style="-fx-opacity: 0.7;" />

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 5 0;">
        <children>
            <Button text="⚙️ فیلترها" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" prefHeight="35.0"/>

            <HBox alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;" HBox.hgrow="ALWAYS" prefHeight="35.0">
                <children>
                    <TextField fx:id="searchField" promptText="جستجو در آگهی‌ها..." style="-fx-background-color: transparent; -fx-alignment: center_right;" HBox.hgrow="ALWAYS" prefHeight="35.0"/>

                    <Button text="🔍" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 0 4 4 0; -fx-border-radius: 0 4 4 0; -fx-cursor: hand; -fx-font-weight: bold;" prefHeight="35.0" prefWidth="40.0"/>
                </children>
            </HBox>
        </children>
    </HBox>

    <ListView fx:id="adListView" prefHeight="544.0" prefWidth="1079.0" style="-fx-background-color: white; -fx-background-radius: 8px;" VBox.vgrow="ALWAYS" />

</VBox>
